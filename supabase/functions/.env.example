# Euda edge-function secrets — TEMPLATE (copy to supabase/functions/.env for
# local `supabase functions serve`; set the real values as Supabase function
# secrets in each project's dashboard for deployed functions).
#
# Only the Sentry vars are documented here (Chief Engineer Phase 2). Other
# secrets (ANTHROPIC_API_KEY, service-role key, etc.) are auto-injected by the
# platform or managed in the Supabase dashboard.

# Sentry crash reporting for EDGE functions (euda-edge project).
# Leave empty to disable (no-op). See supabase/functions/_shared/sentry.ts.
SENTRY_DSN_EDGE=

# Environment tag for edge Sentry events: prod | staging. MUST match the
# mobile Env.APP_ENV values ("prod"/"staging") and the Sentry alert rule's
# environment filter, or alerts won't fire. Set "staging" on the staging project.
SENTRY_ENV=prod

# --- Monitoring (Phase 3b) ---
# Slack Incoming Webhook for monitoring alerts (recommend a dedicated
# #euda-monitoring channel). Leave empty to disable Slack notifications.
SLACK_WEBHOOK_URL=
# Optional: Slack mention appended on `critical` alerts, e.g. <@U01ABCDEF>.
SLACK_ALERT_MENTION=
# Sentry user auth token (org:read/project:read) for monitor-error-rates.
SENTRY_ORG_AUTH_TOKEN=
