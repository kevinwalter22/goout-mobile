{
  "expo": {
    "name": "Euda",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "euda",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "buildNumber": "2",
      "associatedDomains": [
        "applinks:links.euda.live"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Euda needs access to your camera to take photos when you check in at events.",
        "NSLocationWhenInUseUsageDescription": "Euda needs your location to verify you are at the event before you can check in.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.euda.app"
    },
    "android": {
      "package": "com.euda.app",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "links.euda.live"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Euda needs your location to verify you are at the event before you can check in."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Euda needs access to your camera to take photos when you check in at events.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Euda uses your contacts to suggest friends. Only hashed phone numbers are processed — your raw contacts never leave your device."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Euda needs access to your photos to update your profile picture."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "euda-mobile",
          "organization": "euda-2e"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#7C3AED"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4c8f3119-7056-4a82-a35a-c0f05b161d8a"
      }
    },
    "owner": "kevwalt22",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/4c8f3119-7056-4a82-a35a-c0f05b161d8a"
    }
  }
}
