# Euda Mobile — STAGING environment template
# Copy to .env.staging (gitignored) and fill in the staging project values.
# For local dev against staging: `cp .env.staging .env && npx expo start`
# These same values are mirrored into the `staging` profile in eas.json.

# Marks this build as staging. Drives Env.APP_ENV, the non-prod banner,
# and Sentry's environment tag. Do NOT rely on the URL containing "staging" —
# real Supabase refs are random strings.
EXPO_PUBLIC_APP_ENV=staging

# Staging Supabase project credentials (Settings → API in the staging project)
EXPO_PUBLIC_SUPABASE_URL=https://<staging-project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<staging-publishable-key>

# Must match the staging DB's phone-hash salt (ALTER DATABASE setting)
EXPO_PUBLIC_PHONE_HASH_SALT=euda_phone_salt_2024

# Optional — staging Sentry DSN (leave blank to disable crash reporting in staging)
EXPO_PUBLIC_SENTRY_DSN=
