{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
  "exclude": [
    "node_modules",
    "supabase/functions",
    "security-tests",
    "preflight-tests",
    "scripts",
    "dist",
    "dist-check",
    "gsd"
  ]
}
