# Cloud Environment template (claude.ai/code) — SHAPE ONLY, no real values here.
# Paste real values (from your local .env.cloud.local, generated for you) into the
# Cloud Environment "Environment variables" field. .env format, NO quotes.
#
# SAFETY: the bare SUPABASE_* values below are the STAGING project's, on purpose —
# so any direct execution from a cloud session hits staging, never prod. Prod is
# reached only through the gated GitHub Actions pipeline. Do NOT put prod write
# creds here. See docs/chief_engineer/multi_interface.md.

# --- Supabase (STAGING-pointed) ---
SUPABASE_URL=                      # staging project URL (NOT prod)
SUPABASE_ANON_KEY=                 # staging anon key
SUPABASE_SERVICE_ROLE_KEY=        # staging service-role key
SUPABASE_ACCESS_TOKEN=            # supabase CLI access token (for npx supabase)
SUPABASE_STAGING_URL=
SUPABASE_STAGING_ANON_KEY=
SUPABASE_STAGING_SERVICE_ROLE_KEY=
SUPABASE_STAGING_DB_PASSWORD=
SUPABASE_STAGING_PROJECT_ID=
# Aliases some scripts/tests read:
STAGING_SUPABASE_URL=
STAGING_SERVICE_ROLE_KEY=

# --- Expo / app client config ---
EXPO_TOKEN=                        # EAS builds/submits
EXPO_PUBLIC_SUPABASE_URL=          # staging for cloud
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_PHONE_HASH_SALT=

# --- Sentry ---
SENTRY_DSN_EDGE=
SENTRY_AUTH_TOKEN=                 # DSN-scoped; cannot list issues via org API
SENTRY_ORG_AUTH_TOKEN=

# --- Third-party data/source APIs ---
ANTHROPIC_API_KEY=
GOOGLE_PLACES_API_KEY=
PREDICTHQ_API_KEY=
TICKETMASTER_API_KEY=
RESEND_API_KEY=

# --- Test accounts ---
# Security/RLS suite (npm run security:test) — copy from GitHub Secrets:
USER_A_EMAIL=
USER_A_PASSWORD=
USER_B_EMAIL=
USER_B_PASSWORD=
# App role test logins used by some scripts:
ADMIN_EMAIL=
ADMIN_PASSWORD=
NORMAL_EMAIL=
NORMAL_PASSWORD=
REVIEW_EMAIL=
REVIEW_PASSWORD=

# --- GitHub (optional) ---
# Push/PR in cloud uses the Claude GitHub App (no PAT needed). Only add a PAT if
# you want the scripts/gh_api.mjs helper to work in cloud:
# GITHUB_TOKEN=

# --- Prod (DELIBERATELY OMITTED) ---
# Do NOT add SUPABASE_PROD_* / prod service-role / prod DB password here.
# Prod changes go through the gated pipeline, which works from any interface.
