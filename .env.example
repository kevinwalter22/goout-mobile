# Euda Mobile — Environment Variables
# Copy this file to .env and fill in your values.
# See docs/ENVIRONMENTS.md for details.

# Required — Supabase project credentials
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Required — Phone hash salt (must match server-side ALTER DATABASE setting)
EXPO_PUBLIC_PHONE_HASH_SALT=

# Optional — Sentry crash reporting (disabled when empty)
EXPO_PUBLIC_SENTRY_DSN=
