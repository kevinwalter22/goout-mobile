# Euda Mobile — Environment Variables
# Copy this file to .env and fill in your values.
# See docs/ENVIRONMENTS.md for details.

# Optional — which environment this build points at: dev | staging | prod.
# Unset is treated as dev for localhost URLs, prod otherwise. Set explicitly
# in staging/prod builds (see .env.staging.example / .env.production.example).
EXPO_PUBLIC_APP_ENV=dev

# Required — Supabase project credentials
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Required — Phone hash salt (must match server-side ALTER DATABASE setting)
EXPO_PUBLIC_PHONE_HASH_SALT=

# Optional — Sentry crash reporting for the MOBILE app (euda-mobile project).
# Disabled when empty or in __DEV__. Replay/perf are off by default (see
# src/lib/sentry.ts). This is the client DSN (safe to ship in the binary).
EXPO_PUBLIC_SENTRY_DSN=

# Build-time only (NOT shipped to the client) — Sentry source-map upload during
# EAS builds, consumed by the @sentry/react-native/expo plugin (app.json).
# Local: put the real value in .env.local. EAS cloud builds: set as an EAS
# secret (eas env:create / dashboard), NOT here.
SENTRY_AUTH_TOKEN=
